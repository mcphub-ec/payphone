# ─── Payphone MCP Server ───────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores REALES antes de usar.
#   cp .env.example .env && chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# Bearer Token de acceso de la cuenta Payphone.
PAYPHONE_TOKEN=

# Store ID de la sucursal (requerido si el token maneja varias sucursales).
# PAYPHONE_STORE_ID=

# (Opcional) Timeout HTTP en segundos.
# PAYPHONE_HTTP_TIMEOUT=30

# Opciones: sse | http_stream
MCP_TRANSPORT_MODE=sse
MCP_PORT=8000
